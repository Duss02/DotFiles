alt - s : yabai -m window --focus south
alt - w : yabai -m window --focus north
alt - a : yabai -m window --focus west
alt - d : yabai -m window --focus east

alt - z: yabai -m display --focus west
alt - x: yabai -m display --focus east

# flip along y-axis
shift + alt - q : yabai -m space --mirror y-axis

# flip along x-axis
shift + alt - p : yabai -m space --mirror x-axis

# toggle window float
shift + alt - e : yabai -m window --toggle float --grid 4:4:1:1:2:2

# rotate layout clockwise
shift + alt - r : yabai -m space --rotate 270

# maximize a window
shift + alt - m : yabai -m window --toggle zoom-fullscreen

# swap windows
shift + alt - s : yabai -m window --swap south
shift + alt - w : yabai -m window --swap north
shift + alt - a : yabai -m window --swap west
shift + alt - d : yabai -m window --swap east

# move window and split
cmd + alt - s : yabai -m window --warp south
cmd + alt - w : yabai -m window --warp north
cmd + alt - a : yabai -m window --warp west
cmd + alt - d : yabai -m window --warp east


#shift + alt - k : yabai -m window --space prev;
#shift + alt - l : yabai -m window --space next;

# close window
cmd + alt - w : yabai -m window --close


#-----SPACES---------

#move between spaces 
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6

# delete focused space
alt - l : yabai -m space 1 --destroy

shift + alt - 1 : yabai -m window --space 1 --focus
shift + alt - 2 : yabai -m window --space 2 --focus
shift + alt - 3 : yabai -m window --space 3 --focus
shift + alt - 4 : yabai -m window --space 4 --focus
shift + alt - 5 : yabai -m window --space 5 --focus
shift + alt - 6 : yabai -m window --space 6 --focus


# create a new space and follow focus
alt - m : yabai -m space --create && \
                  index="$(yabai -m query --displays --display | jq '.spaces[-1]')" && \
                  yabai -m space --focus "${index}"

# Toggle bar visibility
alt - b : ~/.config/skhd/show_bar.sh
shift + alt - b : ~/.config/skhd/toggle_bar.sh




shift + alt - o : ~/.config/skhd/wup.sh
shift + alt - k : ~/.config/skhd/sdown.sh
shift + alt - j : ~/.config/skhd/toggle_bar.sh
